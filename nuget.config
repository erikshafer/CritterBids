<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Package source routing (PackageSourceMapping).

    The private jasperfx feed (packages.jasperfx.net) only serves the commercial
    JasperFx.AiSkills package; it returns 403 for the open-source Critter Stack line.
    Every WolverineFx* / Marten* / Polecat* package this repo consumes lives on
    nuget.org, so they must resolve there. A prior config pinned WolverineFx*/Marten*/
    Polecat* to jasperfx, which only ever succeeded from a warm local package cache and
    403'd on any clean clone or CI restore (surfaced as NU1101/NU1301 on the first
    cache-miss, e.g. WolverineFx.RabbitMQ / WolverineFx.SignalR). This mirrors the
    user-level NuGet.Config intent: private packages from jasperfx, everything else
    from nuget.org.
  -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="jasperfx">
      <package pattern="JasperFx.AiSkills" />
    </packageSource>
  </packageSourceMapping>
</configuration>
